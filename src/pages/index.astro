---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import profilePic from '../assets/profile-picture.jpg';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recentPosts = posts.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main id="main-content">
			<!-- Hero Section -->
			<section class="hero">
				<div class="hero-layout">
					<div class="hero-content">
						<p class="hero-eyebrow">Product Architect · IEEE Senior Member · Published Researcher</p>
						<h1>From Blacksmiths<br /><span class="accent">to Goldsmiths.</span></h1>
						<p class="hero-subtitle">
							I help engineering teams transition from effort-based labor to high-precision, 
							composable architecture — designed for enterprise scale and built with craftsman's care.
						</p>
						<div class="hero-cta">
							<a href="/blog" class="btn-primary">Read the Blog</a>
							<a href="/about" class="btn-secondary">About Me</a>
						</div>
					</div>
					<div class="hero-photo">
						<Image src={profilePic} alt="Shashi Kumar" width={200} height={200} class="profile-img" />
					</div>
				</div>
			</section>

			<!-- Pillars Section -->
			<section class="pillars">
				<h2 class="section-title">What I Write About</h2>
				<div class="pillars-grid">
					<a href="/blog/tag/architecture" class="pillar-card">
						<span class="pillar-icon">🏗️</span>
						<h3>Software Architecture</h3>
						<p>Hexagonal, DDD, CQRS, and the "Lego Framework" — composable enterprise systems built on company-proven patterns.</p>
					</a>
					<a href="/blog/tag/sdlc" class="pillar-card">
						<span class="pillar-icon">⚙️</span>
						<h3>Enterprise SDLC</h3>
						<p>CI/CD pipelines, API Design-First, and Spec-Driven Development across heterogeneous, technology-agnostic stacks — from legacy modernization to cloud-native integration.</p>
					</a>
					<a href="/blog/tag/ai" class="pillar-card">
						<span class="pillar-icon">🤖</span>
						<h3>AI-Augmented Engineering</h3>
						<p>AI as the "Great Teacher" — leveraging agentic AI to automate the structural 90% of software engineering, empowering humans for the final 10% of business refinement and creative problem-solving.</p>
					</a>
					<a href="/blog/tag/research" class="pillar-card">
						<span class="pillar-icon">📄</span>
						<h3>Published Research</h3>
						<p>Peer-reviewed papers on Domain Autonomy in Microservices, Composable Enterprise, IoT Data Processing, and more.</p>
					</a>
				</div>
			</section>

			<!-- Recent Posts Section -->
			<section class="recent-posts">
				<h2 class="section-title">Latest from the Blog</h2>
				<ul class="posts-list">
					{
						recentPosts.map((post) => (
							<li class="post-card">
								<a href={`/blog/${post.id}/`}>
									<h3>{post.data.title}</h3>
									<p class="post-date">
										{post.data.pubDate.toLocaleDateString('en-us', {
											year: 'numeric',
											month: 'long',
											day: 'numeric',
										})}
									</p>
									<p class="post-desc">{post.data.description}</p>
								</a>
							</li>
						))
					}
				</ul>
				<div class="view-all">
					<a href="/blog">View all posts →</a>
				</div>
			</section>

			<!-- Connect Section -->
			<section class="connect">
				<h2 class="section-title">Let's Connect</h2>
				<p>I'm always open to discussing architecture, enterprise patterns, and agentic AI engineering.</p>
				<div class="connect-links">
					<a href="https://www.linkedin.com/in/shashinkumar/" target="_blank" class="btn-linkedin">
						<svg viewBox="0 0 24 24" width="20" height="20" style="vertical-align: middle; margin-right: 0.4em;">
							<path fill="currentColor" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
						</svg>
						Connect on LinkedIn
					</a>
					<a href="https://github.com/kumarshaz" target="_blank" class="btn-github">
						<svg viewBox="0 0 16 16" width="20" height="20" style="vertical-align: middle; margin-right: 0.4em;">
							<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path>
						</svg>
						View GitHub
					</a>
					<a href="https://dzone.com/users/5309856/snkumar.html" target="_blank" class="btn-dzone">
						<svg viewBox="0 0 32 32" width="20" height="20" style="vertical-align: middle; margin-right: 0.4em;">
							<rect width="32" height="32" rx="4" fill="currentColor" opacity="0.15"/>
							<text x="16" y="22" text-anchor="middle" font-family="Arial,sans-serif" font-weight="bold" font-size="16" fill="currentColor">DZ</text>
						</svg>
						DZone Publications
					</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	/* ===== Hero Section ===== */
	.hero {
		text-align: center;
		padding: 4em 1em 3em;
		background: linear-gradient(135deg, #0f1219 0%, #1a1f2e 50%, #0f1219 100%);
		margin: -3em calc(-50vw + 50%) 0;
		padding-left: calc(50vw - 50%);
		padding-right: calc(50vw - 50%);
		color: #fff;
		transition: background 0.3s ease, color 0.3s ease;
	}
	:global(.light) .hero {
		background: linear-gradient(135deg, #eef1f8 0%, #dfe4f0 50%, #eef1f8 100%);
		color: rgb(15, 18, 25);
	}
	:global(.light) .hero h1 {
		color: rgb(15, 18, 25);
	}
	:global(.light) .hero h1 .accent {
		color: var(--accent);
	}
	:global(.light) .hero-eyebrow {
		color: var(--accent);
	}
	:global(.light) .hero-subtitle {
		color: rgba(15, 18, 25, 0.78);
	}
	:global(.light) .btn-secondary {
		border-color: rgba(15, 18, 25, 0.3);
		color: rgba(15, 18, 25, 0.8) !important;
	}
	:global(.light) .btn-secondary:hover {
		border-color: var(--accent);
		color: var(--accent) !important;
	}
	:global(.light) .hero-photo .profile-img {
		border-color: rgba(15, 18, 25, 0.1);
		box-shadow: 0 0 40px rgba(35, 55, 255, 0.12);
	}
	.hero-layout {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 3em;
		max-width: 860px;
		margin: 0 auto;
	}
	.hero-content {
		flex: 1;
		text-align: left;
	}
	.hero-photo {
		flex-shrink: 0;
	}
	.hero-photo .profile-img {
		width: 180px;
		height: 180px;
		border-radius: 50%;
		border: 3px solid rgba(255, 255, 255, 0.15);
		box-shadow: 0 0 40px rgba(35, 55, 255, 0.25);
		object-fit: cover;
	}
	.hero-eyebrow {
		font-size: 0.75em;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: var(--accent);
		margin-bottom: 0.5em;
		font-weight: 600;
	}
	.hero h1 {
		font-size: 3em;
		line-height: 1.1;
		margin-bottom: 0.5em;
		color: #fff;
	}
	.hero h1 .accent {
		color: var(--accent);
	}
	.hero-subtitle {
		font-size: 1.1em;
		color: rgba(255, 255, 255, 0.7);
		max-width: 560px;
		margin: 0 auto 1.5em;
		line-height: 1.6;
	}
	.hero-cta {
		display: flex;
		gap: 1em;
		justify-content: center;
		flex-wrap: wrap;
	}
	.btn-primary {
		display: inline-block;
		background: var(--accent);
		color: #fff !important;
		padding: 0.75em 2em;
		border-radius: 6px;
		text-decoration: none;
		font-weight: 700;
		font-size: 0.95em;
		transition: background 0.2s ease, transform 0.15s ease;
	}
	.btn-primary:hover {
		background: var(--accent-dark);
		transform: translateY(-2px);
	}
	.btn-secondary {
		display: inline-block;
		border: 2px solid rgba(255, 255, 255, 0.3);
		color: rgba(255, 255, 255, 0.9) !important;
		padding: 0.75em 2em;
		border-radius: 6px;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.95em;
		transition: border-color 0.2s ease, color 0.2s ease;
	}
	.btn-secondary:hover {
		border-color: var(--accent);
		color: #fff !important;
	}

	/* ===== Section Titles ===== */
	.section-title {
		text-align: center;
		margin-bottom: 1.5em;
		font-size: 1.8em;
		color: rgb(var(--black));
		position: relative;
	}
	.section-title::after {
		content: '';
		display: block;
		width: 60px;
		height: 3px;
		background: var(--accent);
		margin: 0.4em auto 0;
		border-radius: 2px;
	}

	/* ===== Pillars Section ===== */
	.pillars {
		padding: 3em 0;
	}
	.pillars-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5em;
	}
	.pillar-card {
		display: block;
		background: var(--bg-primary);
		border: 1px solid rgb(var(--gray-light));
		border-radius: 12px;
		padding: 1.5em;
		text-decoration: none;
		color: inherit;
		transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
	}
	.pillar-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--box-shadow);
		border-color: var(--accent);
	}
	.pillar-icon {
		font-size: 2em;
		display: block;
		margin-bottom: 0.3em;
	}
	.pillar-card h3 {
		font-size: 1.1em;
		margin-bottom: 0.4em;
		color: rgb(var(--black));
	}
	.pillar-card p {
		font-size: 0.85em;
		color: rgb(var(--gray));
		line-height: 1.6;
		margin: 0;
	}

	/* ===== Recent Posts Section ===== */
	.recent-posts {
		padding: 2em 0 3em;
	}
	.posts-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1em;
	}
	.post-card {
		background: var(--bg-primary);
		border: 1px solid rgb(var(--gray-light));
		border-radius: 10px;
		padding: 1.5em;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}
	.post-card:hover {
		transform: translateY(-2px);
		box-shadow: var(--box-shadow);
	}
	.post-card a {
		text-decoration: none;
		color: inherit;
	}
	.post-card h3 {
		margin: 0 0 0.3em;
		font-size: 1.15em;
		color: rgb(var(--black));
	}
	.post-date {
		font-size: 0.78em;
		color: rgb(var(--gray));
		margin: 0 0 0.5em;
	}
	.post-desc {
		font-size: 0.88em;
		color: rgb(var(--gray-dark));
		margin: 0;
		line-height: 1.5;
	}
	.view-all {
		text-align: center;
		margin-top: 1.5em;
	}
	.view-all a {
		font-weight: 600;
		text-decoration: none;
		color: var(--accent);
	}
	.view-all a:hover {
		text-decoration: underline;
	}

	/* ===== Connect Section ===== */
	.connect {
		text-align: center;
		padding: 2em 0 3em;
		border-top: 1px solid rgb(var(--gray-light));
	}
	.connect p {
		color: rgb(var(--gray));
		max-width: 500px;
		margin: 0 auto 1.5em;
	}
	.connect-links {
		display: flex;
		gap: 1em;
		justify-content: center;
		flex-wrap: wrap;
	}
	.btn-linkedin {
		display: inline-flex;
		align-items: center;
		background: #0a66c2;
		color: #fff !important;
		padding: 0.7em 1.5em;
		border-radius: 6px;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.9em;
		transition: background 0.2s ease;
	}
	.btn-linkedin:hover {
		background: #004182;
	}
	.btn-github {
		display: inline-flex;
		align-items: center;
		background: #24292e;
		color: #fff !important;
		padding: 0.7em 1.5em;
		border-radius: 6px;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.9em;
		transition: background 0.2s ease;
	}
	.btn-github:hover {
		background: #000;
	}
	.btn-dzone {
		display: inline-flex;
		align-items: center;
		background: #1e6b3a;
		color: #fff !important;
		padding: 0.7em 1.5em;
		border-radius: 6px;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.9em;
		transition: background 0.2s ease;
	}
	.btn-dzone:hover {
		background: #145228;
	}

	/* ===== Responsive ===== */
	@media (max-width: 720px) {
		.hero-layout {
			flex-direction: column-reverse;
			text-align: center;
			gap: 1.5em;
		}
		.hero-content {
			text-align: center;
		}
		.hero-subtitle {
			margin-left: auto;
			margin-right: auto;
		}
		.hero h1 {
			font-size: 2.2em;
		}
		.hero-photo .profile-img {
			width: 140px;
			height: 140px;
		}
		.pillars-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
