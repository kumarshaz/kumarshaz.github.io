---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<a href="#main-content" class="skip-link">Skip to content</a>
<header role="banner">
	<nav aria-label="Primary navigation">
		<div class="brand">
			<h2><a href="/">{SITE_TITLE}</a></h2>
			<span class="tagline">Architecture · Leadership · AI</span>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="header-actions">
			<button id="theme-toggle" class="theme-toggle" title="Toggle light/dark mode" aria-label="Toggle light/dark mode" type="button">
				<svg class="icon-sun" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
					<circle cx="12" cy="12" r="5"></circle>
					<line x1="12" y1="1" x2="12" y2="3"></line>
					<line x1="12" y1="21" x2="12" y2="23"></line>
					<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
					<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
					<line x1="1" y1="12" x2="3" y2="12"></line>
					<line x1="21" y1="12" x2="23" y2="12"></line>
					<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
					<line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
				</svg>
				<svg class="icon-moon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
					<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
				</svg>
			</button>
		</div>
	</nav>
</header>
<style>
	/* Skip Navigation Link (A11y — visually hidden until Tab-focused) */
	.skip-link {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
		background: var(--accent);
		color: #fff;
		text-decoration: none;
		font-weight: 700;
		z-index: 1000;
	}
	.skip-link:focus {
		position: fixed;
		top: 0;
		left: 0;
		width: auto;
		height: auto;
		padding: 0.75em 1.5em;
		margin: 0;
		overflow: visible;
		clip: auto;
		white-space: normal;
		border-radius: 0 0 6px 0;
	}
	header {
		margin: 0;
		padding: 0 1.5em;
		background: linear-gradient(135deg, #0f1219 0%, #1a1f2e 100%);
		box-shadow: 0 2px 16px rgba(0, 0, 0, 0.3);
		border-bottom: 2px solid var(--accent);
	}
	.brand {
		display: flex;
		flex-direction: column;
		gap: 0;
	}
	.tagline {
		font-size: 0.65em;
		color: rgba(255, 255, 255, 0.5);
		letter-spacing: 0.15em;
		text-transform: uppercase;
		margin-top: -0.3em;
	}
	h2 {
		margin: 0;
		font-size: 1.15em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: #fff;
		font-weight: 700;
		letter-spacing: 0.02em;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: rgba(255, 255, 255, 0.8);
		border-bottom: 3px solid transparent;
		text-decoration: none;
		transition: color 0.2s ease, border-bottom-color 0.2s ease;
	}
	nav a:hover {
		color: #fff;
	}
	nav a.active {
		text-decoration: none;
		color: #fff;
		border-bottom-color: var(--accent);
	}
	/* ===== Light Mode Header ===== */
	:global(.light) header {
		background: linear-gradient(135deg, #f0f2f8 0%, #e4e8f2 100%);
		box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
		border-bottom-color: var(--accent);
	}
	:global(.light) h2 a,
	:global(.light) h2 a.active {
		color: rgb(15, 18, 25);
	}
	:global(.light) .tagline {
		color: rgba(15, 18, 25, 0.45);
	}
	:global(.light) nav a {
		color: rgba(15, 18, 25, 0.7);
	}
	:global(.light) nav a:hover {
		color: rgb(15, 18, 25);
	}
	:global(.light) nav a.active {
		color: rgb(15, 18, 25);
	}
	:global(.light) .theme-toggle {
		color: rgba(15, 18, 25, 0.5);
	}
	:global(.light) .theme-toggle:hover {
		color: var(--accent);
	}
	/* Header Actions (theme toggle) */
	.header-actions {
		display: flex;
		align-items: center;
	}
	/* Theme Toggle */
	.theme-toggle {
		background: none;
		border: none;
		padding: 0.5em;
		cursor: pointer;
		color: rgba(255, 255, 255, 0.6);
		display: flex;
		align-items: center;
		justify-content: center;
		transition: color 0.2s ease;
		border-radius: 4px;
	}
	.theme-toggle:hover {
		color: var(--accent);
	}
	.theme-toggle:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}
	/* Show sun in dark mode, moon in light mode */
	:global(.light) .icon-sun { display: none; }
	:global(.light) .icon-moon { display: block; }
	:global(.dark) .icon-sun { display: block; }
	:global(.dark) .icon-moon { display: none; }
	/* Default: dark mode */
	.icon-sun { display: block; }
	.icon-moon { display: none; }
	@media (max-width: 720px) {
		.tagline {
			display: none;
		}
		header {
			padding: 0 0.75em;
		}
		nav {
			flex-wrap: wrap;
			gap: 0;
		}
		/* Brand + toggle share the top row */
		.brand {
			order: 1;
			flex: 1;
		}
		.header-actions {
			order: 2;
		}
		/* Nav links go to their own row below */
		.internal-links {
			order: 3;
			width: 100%;
			display: flex;
			justify-content: center;
			gap: 0.25em;
			border-top: 1px solid rgba(255, 255, 255, 0.1);
		}
		:global(.light) .internal-links {
			border-top-color: rgba(15, 18, 25, 0.1);
		}
		h2 {
			font-size: 0.95em;
		}
		nav a {
			padding: 0.6em 0.5em;
			font-size: 0.85em;
		}
		.theme-toggle {
			padding: 0.35em;
		}
	}
</style>
<script is:inline>
	// Theme toggle — runs immediately to prevent flash of wrong theme
	(function() {
		const theme = localStorage.getItem('theme') || 'dark';
		document.documentElement.classList.remove('light', 'dark');
		document.documentElement.classList.add(theme);
	})();
	document.addEventListener('DOMContentLoaded', () => {
		const btn = document.getElementById('theme-toggle');
		if (btn) {
			btn.addEventListener('click', () => {
				const isDark = document.documentElement.classList.contains('dark');
				const next = isDark ? 'light' : 'dark';
				document.documentElement.classList.remove('light', 'dark');
				document.documentElement.classList.add(next);
				localStorage.setItem('theme', next);
			});
		}
	});
</script>
